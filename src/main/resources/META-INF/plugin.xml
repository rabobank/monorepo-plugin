<?xml version="1.0" encoding="UTF-8"?>
<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>com.github.martinvisser.monorepoplugin</id>
    <name>Monorepo</name>
    <vendor>Martin Visser</vendor>

    <description><![CDATA[
    A plugin to filter the project view based on the code-owners.json configuration.
    It allows users to limit visible files to those owned by specific teams, making it easier to navigate monorepo projects.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <resource-bundle>messages.ResourceBundle</resource-bundle>

    <extensions defaultExtensionNs="com.intellij">
        <postStartupActivity
            implementation="com.github.martinvisser.monorepoplugin.startup.MonorepoPluginStartupActivity"/>
        <treeStructureProvider
            implementation="com.github.martinvisser.monorepoplugin.provider.MonorepoTreeStructureProvider"/>

        <toolWindow id="Monorepo Team Filter"
                    anchor="right"
                    factoryClass="com.github.martinvisser.monorepoplugin.toolwindow.MonorepoTeamFilterToolWindowFactory"
                    icon="/icons/codeOwners.svg"
        />

        <statusBarWidgetFactory id="Monorepo Status bar widget"
                                implementation="com.github.martinvisser.monorepoplugin.ui.MonorepoOwnerStatusWidgetFactory"/>

        <projectConfigurable
            parentId="tools"
            instance="com.github.martinvisser.monorepoplugin.settings.MonorepoSettings"
            displayName="Monorepo Team Filter"/>
    </extensions>

</idea-plugin>
