{
    "$schema": "code-owners.schema.json",
    "teams": {
        "Quantum Falcons": {
            "paths": [
                "/src/components/*",
                "/src/utils/helpers/*"
            ]
        },
        "Pixel Ninjas": {
            "paths": [
                "/libs/widgets/*",
                "/libs/pages/dashboard/*",
                "/libs/mocks/testdata/*",
                "!/libs/mocks/testdata/legacy/*"
            ]
        },
        "Nebula Coders": {
            "paths": [
                "/libs/features/galaxy/warp-drive/*",
                "/libs/pages/nebula/settings/space-cards/blackhole/_index/*",
                "/libs/pages/nebula/settings/space-cards/blackhole/warp-drive/*",
                "/libs/pages/andromeda/settings/space-cards/blackhole/warp-drive/*",
                "/libs/nebula/redirect/*",
                "!/libs/nebula/redirect/src/lib/alien-conditions.service.ts",
                "/libs/mocks/nebula/__files/server/blackhole-warp-drive/*",
                "/libs/mocks/andromeda/__files/server/blackhole-warp-drive/*",
                "/libs/mocks/nebula/mappings/api/space/galaxy/warp/*",
                "/libs/mocks/andromeda/mappings/api/space/galaxy/warp/*",
                "/apps/nebula-e2e/spec/settings/blackhole/warp.spec.ts",
                "/apps/nebula-e2e/async/objects/pages/self-manage/blackhole/*",
                "/apps/nebula-e2e/async/objects/pages/settings/blackhole/warp-drive.page.ts",
                "/libs/mocks/nebula/mappings/api/space/profiles/conditions/warp_usercondition.json"
            ]
        },
        "Code Pirates": {
            "paths": [
                "/apps/treasure-hunt-e2e/*",
                "/apps/treasure-hunt/*",
                "/apps/ghost-ship-e2e/*",
                "/apps/ghost-ship/*",
                "/apps/andromeda-e2e/spec/online-status-treasure/online-status-treasure.spec.ts",
                "/apps/nebula-e2e/spec/dashboard/online-status-treasure.spec.ts",
                "/libs/common/online-status-treasure/*",
                "/libs/features/misc/qr-treasure/*",
                "/libs/features/ghost/*",
                "/libs/mocks/treasure-hunt/*",
                "/libs/mocks/ghost/*",
                "/libs/mocks/andromeda/mappings/api/ghost/messages/*",
                "/libs/mocks/nebula/__files/online-status-treasure/*",
                "/libs/mocks/nebula/mappings/api/disturbances/*",
                "/libs/mocks/nebula/mappings/api/ghost/messages/*",
                "!/libs/mocks/nebula/mappings/api/ghost/messages/treasure-level-messages-all.json",
                "!/libs/mocks/nebula/mappings/api/ghost/messages/treasure-level-messages-gold.json",
                "!/libs/mocks/nebula/mappings/api/ghost/messages/treasure-level-messages-silver.json",
                "!/libs/mocks/nebula/mappings/api/ghost/messages/treasure-level-messages-bronze.json",
                "!/libs/mocks/nebula/mappings/api/ghost/messages/treasure-level-messages-emerald.json",
                "!/libs/mocks/nebula/mappings/api/ghost/messages/treasure-level-messages-pearl.json",
                "/libs/ghost/*",
                "/libs/pages/ghost/*"
            ]
        }
    }
}
